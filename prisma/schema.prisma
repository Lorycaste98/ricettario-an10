generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          Int      @id @default(autoincrement())
  name        String
  servings    Int?
  /** Unità delle porzioni (es. "teglie da 28cm", "pirofile"); nullo = persone/porzioni */
  servingsUnit String?
  prep        Int?
  cook        Int?
  notes       String?
  links       String?
  photo       String?
  cookCount   Int      @default(0)
  published   Boolean  @default(true)
  /** Ricetta "veloce": solo nome, senza scheda. Selezionabile nei menù ma esclusa da libreria/ricerca e senza pagina di dettaglio. */
  quick       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  RecipeCategory[]
  ingredients Ingredient[]
  steps       Step[]
  photos      RecipePhoto[]
  tags        RecipeTag[]
  reviews     Review[]
  menus       MenuRecipe[]
  cookLogs    CookLog[]
  progress    RecipeProgress[]
}

model CookLog {
  id        Int      @id @default(autoincrement())
  cookedAt  DateTime @default(now())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([cookedAt])
  @@index([recipeId])
}

model Category {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  color     String
  sortOrder Int              @default(0)
  recipes   RecipeCategory[]
}

model RecipeCategory {
  recipeId   Int
  categoryId Int
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([recipeId, categoryId])
}

model Ingredient {
  id          Int     @id @default(autoincrement())
  name        String
  qty         Float?
  unit        String?
  description String?
  /** Ingrediente facoltativo: mostrato con l'etichetta "opzionale" (dettaglio, lista spesa, PDF) */
  optional    Boolean @default(false)
  order       Int
  recipeId    Int
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model IngredientMaster {
  id                Int     @id @default(autoincrement())
  name              String  @unique
  excludedFromStats Boolean @default(false)
}

model Step {
  id       Int    @id @default(autoincrement())
  text     String
  mins     Int?
  /** Tipo di tempo dello step: PREP | COOK | WAIT (attesa passiva) */
  kind     String @default("PREP")
  order    Int
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipePhoto {
  id       Int    @id @default(autoincrement())
  url      String
  order    Int    @default(0)
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Tag {
  id      Int         @id @default(autoincrement())
  name    String      @unique
  recipes RecipeTag[]
}

model RecipeTag {
  recipeId Int
  tagId    Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id])

  @@id([recipeId, tagId])
}

model Review {
  id        Int      @id @default(autoincrement())
  nickname  String
  /** Voto 1-10. Le recensioni con menuId nullo sono note personali dell'admin (nessun voto pubblico diretto). */
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  /** Menù da cui arriva la recensione (nullo = nota personale dell'admin, non legata a un'occasione specifica). */
  menuId    Int?
  menu      Menu?    @relation(fields: [menuId], references: [id], onDelete: SetNull)
}

model Admin {
  id         Int     @id @default(autoincrement())
  username   String  @unique
  password   String
  role       String  @default("ADMIN")
  firstLogin Boolean @default(true)
  dedication String?

  recipeProgress RecipeProgress[]
}

/** Avanzamento passi di una ricetta per admin (persistito per account, sync tra dispositivi) */
model RecipeProgress {
  adminId    Int
  recipeId   Int
  /** Indici 0-based degli step completati — gli id degli step sono instabili (delete-recreate al PUT ricetta) */
  doneSteps  Int[]    @default([])
  /** Numero di step al momento del salvataggio: guardia anti-stale */
  stepsCount Int      @default(0)
  updatedAt  DateTime @updatedAt

  admin  Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([adminId, recipeId])
}

model Menu {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  date        DateTime?
  /** Orario di servizio "HH:mm" (opzionale); usato per il countdown "quando iniziare" */
  servingTime String?
  photo       String?
  /** Token segreto per il link pubblico "recensisci le ricette di questo menù" (/recensisci/[token]) */
  reviewToken String       @unique
  /** Contatore recensioni anonime di questo menù: alimenta il nickname progressivo "Ospite N" */
  anonymousReviewCount Int @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  recipes       MenuRecipe[]
  /** Storico: recensioni al menù nel suo complesso, formato dismesso — non se ne creano più di nuove */
  reviews       MenuReview[]
  /** Recensioni ricetta arrivate tramite il link di recensione di questo menù */
  recipeReviews Review[]
}

model MenuRecipe {
  menuId    Int
  recipeId  Int
  order     Int    @default(0)
  /** Inizio pianificato della ricetta nella modalità cucina (timeline); nullo = calcolo automatico dal servizio */
  cookStartAt DateTime?
  menu      Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([menuId, recipeId])
}

model MenuReview {
  id        Int      @id @default(autoincrement())
  nickname  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  menuId    Int
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
}
